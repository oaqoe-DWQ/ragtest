# Ragas数据生成器环境变量配置

# ===========================================
# 召回接口配置
# ===========================================
# 召回接口的认证密钥（如果需要）
RETRIEVAL_API_KEY=

# 知识库ID，可选值: parsed_files_title_re, parsed_files
# 默认为 parsed_files_title_re
KNOWLEDGE_ID=parsed_files_title_re

# ===========================================
# Dify LLM接口配置
# ===========================================
# Dify API地址
DIFY_URL=https://ai.zy.com/v1/chat-messages

# Dify API密钥（格式: Bearer app-xxx）
DIFY_API_KEY=Bearer app-your-api-key-here

# ===========================================
# 检索参数配置（可选）
# ===========================================
# 返回结果数量
TOP_K=5

# 相关性阈值（0-1）
SCORE_THRESHOLD=0.5

# 向量权重（0-1）
VECTOR_WEIGHT=0.8
